{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Blender Mobile 3D Release Manifest",
  "type": "object",
  "required": ["schema_version", "version", "artifacts"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "minimum_blender_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "maximum_blender_version_exclusive": {
      "anyOf": [
        {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        {"type": "null"}
      ]
    },
    "artifacts": {
      "type": "object",
      "required": ["extension"],
      "properties": {
        "extension": {
          "type": "object",
          "required": ["filename", "url", "sha256", "size"],
          "properties": {
            "filename": {"type": "string"},
            "url": {"type": "string", "format": "uri"},
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "size": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
